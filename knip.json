{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    ".": {},
    "packages/devices": {
      "project": ["src/**/*.{ts,tsx}"],
      "ignoreMembers": [
        "OPTIONS_ACK",
        "UNKNOWN",
        "ALPHANUMERIC",
        "NUMERIC",
        "QRCODE",
        "OUTPUT",
        "REMOTE_SET_ACTIVE",
        "REMOTE_ERROR",
        "IME_KEY_INJECT",
        "IME_SHOW_REQUEST",
        "VOICE_BEGIN",
        "VOICE_PAYLOAD",
        "VOICE_END",
        "REMOTE_START",
        "SET_VOLUME_LEVEL",
        "ADJUST_VOLUME_LEVEL"
      ]
    },
    "packages/inspector": {
      "project": ["src/**/*.{ts,tsx}"]
    },
    "apps/tui": {
      "project": ["src/**/*.{ts,tsx}"]
    }
  },
  "ignoreExportsUsedInFile": {
    "interface": true,
    "type": true
  }
}
